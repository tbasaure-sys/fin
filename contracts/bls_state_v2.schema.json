{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bls.local/contracts/bls_state_v2.schema.json",
  "title": "BLS State Contract V2",
  "type": "object",
  "required": [
    "contract_version",
    "model_version",
    "as_of",
    "portfolio_id",
    "horizon_days",
    "measured_state",
    "probabilistic_state",
    "policy_state",
    "recoverability_budget",
    "healing_dynamics",
    "rebound_sponsorship",
    "legitimacy_surface",
    "failure_modes",
    "transition_memory",
    "repair_candidates",
    "analogs",
    "uncertainty"
  ],
  "properties": {
    "contract_version": {"type": "string", "const": "state_contract_v2"},
    "model_version": {"type": "string"},
    "as_of": {"type": ["string", "null"]},
    "portfolio_id": {"type": "string"},
    "horizon_days": {"type": "integer", "minimum": 1},
    "measured_state": {"type": "object"},
    "probabilistic_state": {"type": "object"},
    "policy_state": {"type": "object"},
    "recoverability_budget": {"type": "object"},
    "healing_dynamics": {"type": "object"},
    "rebound_sponsorship": {"type": "object"},
    "legitimacy_surface": {"type": "object"},
    "failure_modes": {"type": "object"},
    "transition_memory": {"type": "object"},
    "repair_candidates": {"type": "array"},
    "analogs": {"type": "array"},
    "uncertainty": {"type": "object"}
  },
  "additionalProperties": false
}
